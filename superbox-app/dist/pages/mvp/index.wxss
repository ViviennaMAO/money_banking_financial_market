.mvp-page{-webkit-box-sizing:border-box;box-sizing:border-box;height:100vh;padding:32rpx 28rpx 80rpx;position:relative}.lang-switch{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;position:absolute;right:28rpx;top:24rpx;z-index:10;-ms-flex-align:center;align-items:center;background:rgba(28,34,54,.7);border:1rpx solid hsla(0,0%,100%,.08);border-radius:9999rpx;gap:6rpx;padding:8rpx 16rpx}.lang-switch:active{background:rgba(245,158,11,.15);border-color:rgba(245,158,11,.4)}.lang-icon{font-size:22rpx;line-height:1}.lang-label{color:#e6edf3;font-family:ui-monospace,Menlo,monospace;font-size:22rpx;font-weight:600}.mvp-hero{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;padding:24rpx 0 32rpx;text-align:center;-ms-flex-align:center;align-items:center}.hero-emoji{font-size:80rpx;line-height:1;margin-bottom:12rpx}.hero-title{color:#e6edf3;font-size:44rpx;font-weight:600;margin-bottom:8rpx}.hero-subtitle{color:rgba(230,237,243,.7);font-size:22rpx;line-height:1.6;padding:0 20rpx;text-align:center}.mvp-list{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:16rpx}.mvp-card{background:rgba(28,34,54,.55);border:1rpx solid rgba(245,158,11,.2);border-radius:20rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:12rpx;padding:24rpx;-webkit-transition:background .2s,border-color .2s;transition:background .2s,border-color .2s}.mvp-card:active{background:rgba(245,158,11,.08);border-color:rgba(245,158,11,.5)}.card-row{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:14rpx;-ms-flex-align:center;align-items:center}.card-emoji{-webkit-flex-shrink:0;font-size:44rpx;line-height:1;-ms-flex-negative:0;flex-shrink:0;text-align:center;width:60rpx}.card-body{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:4rpx}.card-meta{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:baseline;justify-content:space-between;-ms-flex-align:baseline;align-items:baseline}.card-num{color:#8b8fa8;font-size:20rpx}.card-stars{color:#f59e0b;font-size:18rpx;letter-spacing:1rpx}.card-title{color:#e6edf3;font-size:28rpx;font-weight:500;line-height:1.4}.card-hook{-webkit-align-items:flex-start;background:-webkit-linear-gradient(315deg,rgba(245,158,11,.1),rgba(239,68,68,.06));background:linear-gradient(135deg,rgba(245,158,11,.1),rgba(239,68,68,.06));border-radius:12rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:10rpx;padding:14rpx 16rpx;-ms-flex-align:start;align-items:flex-start}.hook-flag{-webkit-flex-shrink:0;font-size:24rpx;-ms-flex-negative:0;flex-shrink:0;line-height:1.4}.hook-text{color:rgba(245,158,11,.95);-webkit-flex:1;-ms-flex:1;flex:1;font-size:22rpx;line-height:1.5}.card-cta{color:#3b82f6;font-size:22rpx;font-weight:500;text-align:right}.footer-note{color:#8b8fa8;font-size:20rpx;line-height:1.6;margin-top:32rpx;text-align:center}