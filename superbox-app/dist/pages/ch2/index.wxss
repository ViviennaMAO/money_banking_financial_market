.ch2{-webkit-box-sizing:border-box;box-sizing:border-box;height:100vh;padding:32rpx 28rpx 80rpx}.page-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:baseline;justify-content:space-between;-ms-flex-align:baseline;align-items:baseline;margin-bottom:24rpx}.page-title{color:#e6edf3;font-size:36rpx;font-weight:600}.page-meta{color:#8b8fa8;font-size:22rpx}.intro-card{background:rgba(59,130,246,.05);border:1rpx solid rgba(59,130,246,.2);border-radius:24rpx;padding:24rpx}.intro-text{color:rgba(230,237,243,.9);font-size:26rpx;line-height:1.7}.tax-card{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;margin-top:24rpx;padding:28rpx}.tax-tag{color:#8b8fa8;display:block;font-size:22rpx;margin-bottom:16rpx}.tax-row{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:14rpx;-ms-flex-align:center;align-items:center;border:1rpx solid;border-radius:12rpx;margin-bottom:10rpx;padding:14rpx 16rpx}.tax-direct-primary{background:rgba(59,130,246,.06);border-color:rgba(59,130,246,.25)}.tax-direct-secondary{background:rgba(167,139,250,.06);border-color:rgba(167,139,250,.25)}.tax-indirect{background:rgba(16,185,129,.06);border-color:rgba(16,185,129,.25)}.tax-emoji{-webkit-flex-shrink:0;font-size:32rpx;line-height:1;-ms-flex-negative:0;flex-shrink:0;text-align:center;width:50rpx}.tax-body{-webkit-flex:1;-ms-flex:1;flex:1}.tax-name{color:#e6edf3;display:block;font-size:24rpx;font-weight:500}.tax-desc{color:rgba(230,237,243,.75);display:block;font-size:22rpx;line-height:1.6;margin-top:2rpx}.game-card{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;margin-top:24rpx;padding:28rpx}.game-tag{color:#8b8fa8;display:block;font-size:22rpx;margin-bottom:16rpx}.tool-row{border-bottom:1rpx dashed hsla(0,0%,100%,.06);padding:14rpx 0}.tool-row:last-of-type{border-bottom:none}.tool-header{-webkit-align-items