.news{-webkit-box-sizing:border-box;box-sizing:border-box;height:100vh;padding:32rpx 28rpx 80rpx}.page-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:baseline;justify-content:space-between;-ms-flex-align:baseline;align-items:baseline;margin-bottom:12rpx}.page-title{color:#e6edf3;font-size:36rpx;font-weight:600}.page-meta{color:#8b8fa8;font-size:22rpx}.intro{color:#8b8fa8;display:block;font-size:24rpx;line-height:1.6}.card{background:#131826;border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;margin-top:24rpx;overflow:hidden}.card-news{background:-webkit-linear-gradient(315deg,rgba(59,130,246,.1),transparent);background:linear-gradient(135deg,rgba(59,130,246,.1),transparent);border-bottom:1rpx solid hsla(0,0%,100%,.05);padding:28rpx}.news-date{color:#3b82f6;display:block;font-size:22rpx;margin-bottom:12rpx}.news-title{color:#e6edf3;display:block;font-size:30rpx;font-weight:500;line-height:1.4}.news-detail{color:#8b8fa8;display:block;font-size:24rpx;line-height:1.6;margin-top:12rpx}.card-section{border-bottom:1rpx solid hsla(0,0%,100%,.05);padding:28rpx}.section-tag{color:#8b8fa8;display:block;font-size:22rpx;margin-bottom:16rpx}.kpi-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;color:rgba(230,237,243,.85);font-size:26rpx;justify-content:space-between;padding:8rpx 0}.kpi-neg{color:#ef4444;font-family:ui-monospace,Menlo,monospace}.kpi-warn{color:#f59e0b;font-family:ui-monospace,Menlo,monospace}.theory{color:rgba(230,237,243,.85);font-size:26rpx;line-height:1.7}.card-q{background:-webkit-linear-gradient(315deg,rgba(245,158,11,.08),transparent);background:linear-gradient(135deg,rgba(245,158,11,.08),transparent)}.q-tag{color:#f59e0b;display:block;font-size:22rpx;margin-bottom:12rpx}.q-text{color:#e6edf3;display:block;font-size:26rpx}.q-options{display:-webkit-flex;display:-ms-flexbox;display:flex;gap:12rpx;margin-top:20rpx}.q-btn{background:hsla(0,0%,100%,.05);border:1rpx solid hsla(0,0%,100%,.1);border-radius:12rpx;color:#e6edf3;-webkit-flex:1;-ms-flex:1;flex:1;font-size:22rpx;padding:16rpx}.q-btn::after{border:none}.q-btn.picked{background:rgba(59,130,246,.2);border-color:rgba(59,130,246,.4);color:#3b82f6}.q-after{color:#8b8fa8;display:block;font-size:20rpx;margin-top:16rpx}.card-actions{border-top:1rpx solid hsla(0,0%,100%,.05);display:-webkit-flex;display:-ms-flexbox;display:flex;gap:12rpx;padding:24rpx 28rpx}.action-share,.action-sim{border-radius:12rpx;-webkit-flex:1;-ms-flex:1;flex:1;font-size:22rpx;font-weight:500;padding:16rpx}.action-share::after,.action-sim::after{border:none}.action-share{background:rgba(59,130,246,.15);color:#3b82f6}.action-sim{background:hsla(0,0%,100%,.05);color:#e6edf3}