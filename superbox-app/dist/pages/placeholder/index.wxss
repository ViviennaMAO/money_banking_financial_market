.placeholder{-webkit-box-sizing:border-box;box-sizing:border-box;height:100vh;padding:40rpx 28rpx 80rpx}.ph-header{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;padding:40rpx 0;text-align:center;-ms-flex-align:center;align-items:center}.ph-part-tag{color:#8b8fa8;font-size:22rpx;margin-bottom:24rpx}.ph-emoji-big{font-size:96rpx;line-height:1;margin-bottom:24rpx}.ph-ch-num{color:#8b8fa8;font-size:24rpx;margin-bottom:8rpx}.ph-ch-title{color:#e6edf3;font-size:40rpx;font-weight:600;line-height:1.3;padding:0 20rpx;text-align:center}.ph-meta{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:center;-ms-flex-pack:center;gap:60rpx;justify-content:center;margin:16rpx 0 32rpx}.ph-meta-item{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;-ms-flex-align:center;align-items:center;gap:4rpx}.ph-meta-label{color:#8b8fa8;font-size:20rpx}.ph-meta-value{color:#e6edf3;font-size:24rpx}.ph-card{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;margin-top:24rpx;padding:28rpx}.ph-card-tag{color:#3b82f6;display:block;font-size:22rpx;margin-bottom:12rpx}.ph-brief{color:rgba(230,237,243,.85);display:block;font-size:28rpx;line-height:1.7}.ph-status-card{-webkit-align-items:center;background:-webkit-linear-gradient(315deg,rgba(245,158,11,.1),rgba(245,158,11,.04));background:linear-gradient(135deg,rgba(245,158,11,.1),rgba(245,158,11,.04));border:1rpx solid rgba(245,158,11,.3);border-radius:24rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;margin-top:24rpx;padding:40rpx 28rpx;text-align:center;-ms-flex-align:center;align-items:center}.ph-status-emoji{font-size:64rpx;line-height:1;margin-bottom:16rpx}.ph-status-title{color:#f59e0b;font-size:32rpx;font-weight:600;margin-bottom:16rpx}.ph-status-desc{color:rgba(230,237,243,.85);display:block;font-size:26rpx;line-height:1.7;margin-bottom:24rpx}.ph-status-emp{color:#f59e0b;font-weight:500}.ph-status-progress{border-top:1rpx solid hsla(0,0%,100%,.1);color:#8b8fa8;display:block;font-size:22rpx;line-height:1.6;padding-top:24rpx;width:100%}.ph-actions{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:16rpx;margin-top:40rpx}.ph-btn{border-radius:16rpx;font-size:28rpx;font-weight:500;padding:24rpx}.ph-btn::after{border:none}.ph-btn-primary{background:rgba(59,130,246,.15);color:#3b82f6}.ph-btn-primary:active{background:rgba(59,130,246,.25)}.ph-footer{color:#8b8fa8;font-size:20rpx;margin-top:60rpx;text-align:center}.ph-msg{color:#e6edf3;display:block;font-size:32rpx;margin:24rpx 0;text-align:center}.ph-back{background:rgba(59,130,246,.15);border-radius:16rpx;color:#3b82f6;font-size:28rpx;margin-top:32rpx;padding:24rpx}.ph-back::after{border:none}.ph-emoji{display:block;font-size:96rpx;margin-top:80rpx;text-align:center}