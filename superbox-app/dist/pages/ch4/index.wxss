.ch4{-webkit-box-sizing:border-box;box-sizing:border-box;height:100vh;padding:32rpx 28rpx 80rpx}.page-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:baseline;justify-content:space-between;-ms-flex-align:baseline;align-items:baseline;margin-bottom:24rpx}.page-title{color:#e6edf3;font-size:36rpx;font-weight:600}.page-meta{color:#8b8fa8;font-size:22rpx}.panel{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:8rpx;margin-top:24rpx;padding:28rpx}.panel-tag{color:#8b8fa8;font-size:22rpx;margin-bottom:8rpx}.output{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;margin-top:24rpx;padding:28rpx}.output.flash{-webkit-animation:flashRed .7s ease 3;animation:flashRed .7s ease 3}@-webkit-keyframes flashRed{0%,100%{background:rgba(28,34,54,.55);border-color:hsla(0,0%,100%,.05)}50%{background:rgba(239,68,68,.18);border-color:rgba(239,68,68,.4)}}@keyframes flashRed{0%,100%{background:rgba(28,34,54,.55);border-color:hsla(0,0%,100%,.05)}50%{background:rgba(239,68,68,.18);border-color:rgba(239,68,68,.4)}}.output-grid{display:grid;gap:28rpx;grid-template-columns:1fr 1fr}.output-label{color:#8b8fa8;display:block;font-size:22rpx}.output-big{display:block;font-family:ui-monospace,SF Mono,Menlo,monospace;font-size:48rpx;line-height:1;margin-top:4rpx}.output-mid{display:block;font-family:ui-monospace,Menlo,monospace;font-size:36rpx;line-height:1.1;margin-top:4rpx}.output-tiny{color:#8b8fa8;display:block;font-size:18rpx;line-height:1.4;margin-top:6rpx}.pos{color:#10b981}.neg{color:#ef4444}.neu{color:#e6edf3}.output-note{border-top:1rpx solid hsla(0,0%,100%,.1);color:#f59e0b;display:block;font-size:24rpx;line-height:1.7;margin-top:24rpx;padding-top:24rpx}.laws{background:rgba(167,139,250,.05);border:1rpx solid rgba(167,139,250,.2);border-radius:24rpx;margin-top:24rpx;padding:28rpx}.laws-tag{color:#a78bfa;display:block;font-size:22rpx;font-weight:500;margin-bottom:16rpx}.law-item{-webkit-align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:14rpx;-ms-flex-align:start;align-items:flex-start;padding:8rpx 0}.law-num{-webkit-flex-shrink:0;-ms-flex-negative:0;-webkit-align-items:center;background:rgba(167,139,250,.18);border-radius:50%;color:#a78bfa;display:-webkit-flex;display:-ms-flexbox;display:flex;flex-shrink:0;font-size:20rpx;height:32rpx;width:32rpx;-ms-flex-align:center;align-items:center;-webkit-justify-content:center;-ms-flex-pack:center;justify-content:center;line-height:1;margin-top:4rpx}.law-text{color:rgba(230,237,243,.9);-webkit-flex:1;-ms-flex:1;flex:1;font-size:24rpx;line-height:1.7}.hint{color:#8b8fa8;display:block;font-size:22rpx;line-height:1.6;margin-top:24rpx;padding:0 8rpx}