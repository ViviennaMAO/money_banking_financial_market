p-block{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:12rpx}.group-head{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;-ms-flex-align:center;align-items:center;gap:14rpx;padding-bottom:8rpx}.group-emoji{-webkit-flex-shrink:0;font-size:44rpx;line-height:1;-ms-flex-negative:0;flex-shrink:0;text-align:center;width:60rpx}.group-info{-webkit-flex:1;-ms-flex:1;flex:1}.group-title{color:#e6edf3;display:block;font-size:28rpx;font-weight:600}.group-desc{color:rgba(230,237,243,.55);display:block;font-size:20rpx;margin-top:2rpx}.term-list{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:12rpx}.term-card{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:16rpx;padding:20rpx}.term-head{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:baseline;justify-content:space-between;-ms-flex-align:baseline;align-items:baseline;gap:12rpx}.term-zh{color:#e6edf3;-webkit-flex:1;-ms-flex:1;flex:1;font-size:28rpx;font-weight:600}.term-tag{background:hsla(0,0%,100%,.04);border-radius:9999rpx;color:rgba(230,237,243,.5);font-size:18rpx;padding:2rpx 10rpx}.term-en{color:#3b82f6;display:block;font-size:22rpx;font-style:italic;margin-top:4rpx}.term-short{color:rgba(230,237,243,.85);display:block;font-size:22rpx;line-height:1.6;margin-top:12rpx}.term-twist{-webkit-align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;gap:10rpx;-ms-flex-align:start;align-items:flex-start;background:-webkit-linear-gradient(315deg,rgba(245,158,11,.08),rgba(239,68,68,.05));background:linear-gradient(135deg,rgba(245,158,11,.08),rgba(239,68,68,.05));border-radius:12rpx;margin-top:12rpx;padding:12rpx 14rpx}.twist-flag{-webkit-flex-shrink:0;font-size:22rpx;-ms-flex-negative:0;flex-shrink:0;line-height:1.4}.twist-text{color:rgba(245,158,11,.95);-webkit-flex:1;-ms-flex:1;flex:1;font-size:21rpx;line-height:1.5}.term-chapters{border-top:1rpx solid hsla(0,0%,100%,.04);display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:8rpx;margin-top:14rpx;padding-top:12rpx}.ch-link{background:rgba(59,130,246,.08);border-radius:9999rpx;color:#3b82f6;font-size:20rpx;padding:4rpx 12rpx}.ch-link:active{background:rgba(59,130,246,.2)}.footer-note{color:#8b8fa8;font-size:20rpx;margin-top:40rpx;text-align:center}