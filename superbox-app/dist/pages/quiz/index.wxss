.quiz{-webkit-box-sizing:border-box;box-sizing:border-box;height:100vh;padding:32rpx 28rpx 80rpx}.page-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:baseline;justify-content:space-between;-ms-flex-align:baseline;align-items:baseline;margin-bottom:12rpx}.page-title{color:#e6edf3;font-size:36rpx;font-weight:600}.page-meta{color:#8b8fa8;font-size:22rpx}.intro{color:#8b8fa8;display:block;font-size:24rpx;line-height:1.7}.intro-emp{color:rgba(230,237,243,.85)}.qs-card{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:40rpx;margin-top:24rpx;padding:28rpx}.q-stem{color:#e6edf3;display:block;font-size:28rpx;font-weight:500;line-height:1.5}.q-opts{display:grid;gap:12rpx;margin-top:20rpx}.q-opts.cols-2{grid-template-columns:1fr 1fr}.q-opts.cols-4{grid-template-columns:1fr 1fr}.q-opt{background:hsla(0,0%,100%,.05);border:1rpx solid hsla(0,0%,100%,.1);border-radius:12rpx;color:#e6edf3;font-size:24rpx;padding:18rpx;text-align:center}.q-opt::after{border:none}.q-opt.picked{background:rgba(59,130,246,.2);border-color:rgba(59,130,246,.4);color:#3b82f6}.design-card{background:rgba(245,158,11,.05);border:1rpx solid rgba(245,158,11,.3);border-radius:24rpx;margin-top:24rpx;padding:28rpx}.design-tag{color:#f59e0b;display:block;font-size:22rpx;font-weight:500;margin-bottom:12rpx}.design-text{color:#e6edf3;display:block;font-size:24rpx;line-height:1.7}.emp{color:#e6edf3;font-weight:500}