.home{-webkit-box-sizing:border-box;box-sizing:border-box;height:100vh;padding:32rpx 28rpx 80rpx}.hero-tag{color:#8b8fa8;display:block;font-size:22rpx;letter-spacing:2rpx;text-transform:uppercase}.hero-title{color:#e6edf3;display:block;font-size:52rpx;font-weight:600;line-height:1.3;margin-top:12rpx}.hero-accent{color:#3b82f6}.hero-warm{color:#f59e0b}.card{-webkit-backdrop-filter:blur(24rpx);backdrop-filter:blur(24rpx);background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;margin-top:40rpx;padding:28rpx}.card-tag{color:#8b8fa8;display:block;font-size:22rpx;margin-bottom:16rpx}.badges{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap;gap:12rpx}.badge{border-radius:9999rpx;display:inline-block;font-size:22rpx;line-height:1.4;padding:6rpx 18rpx}.p-blue{background:rgba(59,130,246,.15);color:#3b82f6}.p-amber{background:rgba(245,158,11,.15);color:#f59e0b}.p-red{background:rgba(239,68,68,.15);color:#ef4444}.p-green{background:rgba(16,185,129,.15);color:#10b981}.p-purple{background:rgba(167,139,250,.15);color:#a78bfa}.p-cyan{background:rgba(6,182,212,.15);color:#06b6d4}.ch-list{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:20rpx;margin-top:40rpx}.section-tag{color:#8b8fa8;display:block;font-size:22rpx;letter-spacing:2rpx;margin-bottom:8rpx;text-transform:uppercase}.ch-card{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;padding:28rpx}.ch-card:active{border-color:rgba(59,130,246,.4)}.ch-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:flex-start;justify-content:space-between;-ms-flex-align:start;align-items:flex-start}.ch-num{color:#8b8fa8;display:block;font-size:22rpx}.ch-title{color:#e6edf3;display:block;font-size:32rpx;font-weight:500;margin-top:4rpx}.ch-meta{color:#8b8fa8;display:block;font-size:22rpx;margin-top:8rpx}.ch-emoji{font-size:48rpx;line-height:1}.ch-hook{color:rgba(230,237,243,.7);font-size:24rpx;line-height:1.6;margin-top:20rpx}.ch-cta{color:#3b82f6;font-size:22rpx;margin-top:12rpx}.footer-note{color:#8b8fa8;font-size:20rpx;margin-top:60rpx;text-align:center}