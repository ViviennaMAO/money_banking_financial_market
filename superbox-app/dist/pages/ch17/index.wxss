.ch17{-webkit-box-sizing:border-box;box-sizing:border-box;height:100vh;padding:32rpx 28rpx 80rpx;position:relative}.lang-switch{-webkit-align-items:center;display:-webkit-flex;display:-ms-flexbox;display:flex;position:absolute;right:28rpx;top:24rpx;z-index:10;-ms-flex-align:center;align-items:center;background:rgba(28,34,54,.7);border:1rpx solid hsla(0,0%,100%,.08);border-radius:9999rpx;gap:6rpx;padding:8rpx 16rpx}.lang-switch:active{background:rgba(167,139,250,.15);border-color:rgba(167,139,250,.4)}.lang-icon{font-size:22rpx;line-height:1}.lang-label{color:#e6edf3;font-family:ui-monospace,Menlo,monospace;font-size:22rpx;font-weight:600}.page-header{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:baseline;justify-content:space-between;-ms-flex-align:baseline;align-items:baseline;margin-bottom:24rpx}.page-title{color:#e6edf3;font-size:36rpx;font-weight:600}.page-meta{color:#8b8fa8;font-size:22rpx}.panel{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:8rpx;margin-top:24rpx;padding:28rpx}.panel-tag{color:#8b8fa8;font-size:22rpx;margin-bottom:8rpx}.output{background:rgba(28,34,54,.55);border:1rpx solid hsla(0,0%,100%,.05);border-radius:24rpx;margin-top:24rpx;padding:28rpx}.output.flash{-webkit-animation:flashRed .7s ease 3;animation:flashRed .7s ease 3}@-webkit-keyframes flashRed{0%,100%{background:rgba(28,34,54,.55);border-color:hsla(0,0%,100%,.05)}50%{background:rgba(239,68,68,.18);border-color:rgba(239,68,68,.4)}}@keyframes flashRed{0%,100%{background:rgba(28,34,54,.55);border-color:hsla(0,0%,100%,.05)}50%{background:rgba(239,68,68,.18);border-color:rgba(239,68,68,.4)}}.output-grid{display:grid;gap:24rpx;grid-template-columns:1fr 1fr}.output-label{color:#8b8fa8;display:block;font-size:22rpx}.output-mid{color:#e6edf3;display:block;font-family:ui-monospace,Menlo,monospace;font-size:36rpx;margin-top:4rpx}.output-big{display:block;font-family:ui-monospace,Menlo,monospace;font-size:48rpx;line-height:1;margin-top:4rpx}.output-big.pos{color:#10b981}.output-big.neg{color:#ef4444}.output-row-bottom{border-top:1rpx solid hsla(0,0%,100%,.1);display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex-direction:column;-ms-flex-direction:column;flex-direction:column;gap:12rpx;margin-top:24rpx;padding-top:24rpx}.br-row{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;-ms-flex-pack:justify;-webkit-align-items:center;justify-content:space-between;-ms-flex-align:center;align-items:center}.br-label{color:#8b8fa8;font-size:24rpx}.br-value{color:#f59e0b;font-family:ui-monospace,Menlo,monospace;font-size:24rpx}.risk{border-radius:9999rpx;font-size:22rpx;line-height:1.4;padding:4rpx 16rpx}.risk-low{background:rgba(16,185,129,.15);color:#10b981}.risk-mid{background:rgba(245,158,11,.15);color:#f59e0b}.risk-high{background:rgba(239,68,68,.15);color:#ef4444}.risk-extreme{-webkit-animation:heartbeat .4s ease infinite;animation:heartbeat .4s ease infinite;background:rgba(239,68,68,.3);color:#ef4444}@-webkit-keyframes heartbeat{0%,100%{-webkit-transform:scale(1);transform:scale(1)}50%{-webkit-transform:scale(1.05);transform:scale(1.05)}}@keyframes heartbeat{0%,100%{-webkit-transform:scale(1);transform:scale(1)}50%{-webkit-transform:scale(1.05);transform:scale(1.05)}}.output-note{border-top:1rpx solid hsla(0,0%,100%,.1);color:#f59e0b;display:block;font-size:24rpx;line-height:1.6;margin-top:24rpx;padding-top:24rpx}.hint{color:#8b8fa8;display:block;font-size:22rpx;line-height:1.6;margin-top:24rpx;padding:0 8rpx}